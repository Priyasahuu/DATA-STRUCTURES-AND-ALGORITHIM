class Solution {
public:
    vector<bool> kidsWithCandies(vector<int>& candies, int extraCandies) {
        
        int n = candies.size();
        vector<bool> ans(n);
        int com=INT_MIN;
         for( int i = 0 ;  i < n  ; i++){
         com= max( com , candies[i]);
         }
         for( int j = 0 ; j  < n  ; j++){
            if( candies[j]+extraCandies >=com)ans[j]=true;
         }
         return ans;
    }
};
