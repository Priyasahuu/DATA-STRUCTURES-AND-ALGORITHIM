class Solution {
public:
    vector<int> shortestToChar(string s, char c) {
    int n = s.size();
     int a=-n;
      vector<int> ans( n , n);
       for( int i = 0 ; i  < n ; i++){
        if(s[i]==c)a=i;
        ans[i]=i-a;
       }   
       for( int i = a-1;i >= 0 ;  --i ){
        if(s[i]==c)a=i;
        ans[i]=min(ans[i],a-i);
       }
       return ans;
    }
};
