class Solution {
public:
    int findLengthOfLCIS(vector<int>& nums) {
       int maxi=0;
       int cnt=0;
     int n = nums.size();
      for( int i = 0 ; i < n ; i ++){
             if(i==0)cnt+=1;
             if( i>0 && nums[i]>nums[i-1]){
                cnt+=1;
             }
             else{
                maxi= max( cnt  , maxi);
                cnt=1;
             }
      } 
      maxi= max( maxi , cnt);
      return maxi; 
    }
};
